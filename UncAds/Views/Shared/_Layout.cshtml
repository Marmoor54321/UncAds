@using Microsoft.AspNetCore.Http.Features
@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Options
@inject IOptions<RequestLocalizationOptions> LocOptions
@using Microsoft.AspNetCore.Http
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture.RequestCulture.UICulture.Name;

    var supportedCultures = LocOptions.Value.SupportedUICultures.Select(c => new
    {
        Name = c.Name,
        DisplayName = c.DisplayName
    }).ToList();

    var returnUrl = string.IsNullOrEmpty(Context.Request.Path) ? "~/" : $"~{Context.Request.Path.Value}";
}

@{
    string currentTheme = Context.Request.Cookies["Theme"] ?? "default";
    string themeCssUrl = "~/lib/bootstrap/dist/css/bootstrap.min.css";

    if (currentTheme == "cyborg")
    {
        themeCssUrl = "~/css/cyborg.css";
    }
    else if (currentTheme == "morph")
    {
        themeCssUrl = "~/css/morph.css";
    }
}

<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UncAds</title>

    <link rel="stylesheet" href="@Url.Content(themeCssUrl)" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UncAds.styles.css" asp-append-version="true" />
    <link rel="alternate" type="application/rss+xml" title="UncAds - RSS" href="/feed" />

    <style>
        .nav-link {
            font-weight: 500;
        }

        main {
            min-height: 80vh;
        }

        body {
            transition: background-color 0.3s ease;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg shadow-sm mb-4 @(currentTheme == "cyborg" ? "navbar-dark bg-dark" : "navbar-light bg-light")">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4" asp-area="" asp-controller="Ads" asp-action="Index">
                    <i class="bi bi-megaphone-fill"></i> UncAds
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent"
                        aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Ads" asp-action="Index">
                                <i class="bi bi-grid"></i> Przeglądaj ogłoszenia
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                        <li class="nav-item me-3">
                            <form id="selectLanguageForm" asp-controller="Home" asp-action="SetLanguage"
                                  asp-route-returnUrl="@returnUrl" method="post" class="d-inline-block">

                                <input type="hidden" name="returnUrl" value="@returnUrl" />

                                <select name="culture" class="form-select form-select-sm"
                                        onchange="this.form.submit();" aria-label="Język">

                        <li class="nav-item dropdown me-3">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-palette-fill"></i> Motyw
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                <li>
                                    <form asp-controller="Home" asp-action="SetTheme" method="post">
                                        <input type="hidden" name="theme" value="default" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <button type="submit" class="dropdown-item @(currentTheme == "default" ? "active" : "")">Domyślny</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-controller="Home" asp-action="SetTheme" method="post">
                                        <input type="hidden" name="theme" value="cyborg" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <button type="submit" class="dropdown-item @(currentTheme == "cyborg" ? "active" : "")">Ciemny</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-controller="Home" asp-action="SetTheme" method="post">
                                        <input type="hidden" name="theme" value="morph" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <button type="submit" class="dropdown-item @(currentTheme == "morph" ? "active" : "")">Niebieski</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                                    @foreach (var culture in supportedCultures)
                                    {
                                        <option value="@culture.Name" selected="@(currentCulture == culture.Name)">
                                            @culture.Name
                                        </option>
                                    }
                                </select>
                            </form>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown me-2">
                                <a class="nav-link dropdown-toggle fw-bold" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock"></i> Panel Admina
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="adminDropdown">
                                    <li><h6 class="dropdown-header">Zarządzanie treścią</h6></li>
                                    <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index">Kategorie</a></li>
                                    <li><a class="dropdown-item" asp-controller="CategoryAttributes" asp-action="Index">Atrybuty</a></li>
                                    <li><a class="dropdown-item" asp-controller="AttributeDictionaries" asp-action="Index">Słowniki</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header">System</h6></li>
                                    <li><a class="dropdown-item" asp-controller="ForbiddenWords" asp-action="Index">Zakazane słowa</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">Użytkownicy</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Settings">Ustawienia globalne</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                    <i class="bi bi-person-circle"></i> Mój profil
                                </a>
                            </li>
                        }

                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Message"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - UncAds - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            | <a href="/feed" target="_blank" style="color: #ee802f; font-weight: bold;">
                <i class="bi bi-rss-fill"></i> RSS
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>