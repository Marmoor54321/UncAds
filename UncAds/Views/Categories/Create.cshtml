@model UncAds.Models.Category
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["CreateCategoryTitle"];
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="m-0 text-success"><i class="bi bi-folder-plus"></i> @Localizer["CreateCategoryHeader"]</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">@Localizer["NameLabel"]</label>
                            <input asp-for="Name" class="form-control" placeholder="@Localizer["NamePlaceholder"]" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ParentCategoryId" class="form-label fw-bold">@Localizer["ParentCategoryLabel"]</label>
                            <select asp-for="ParentCategoryId" class="form-select" asp-items="ViewBag.ParentCategoryId">
                                <option value="">@Localizer["MainCategoryOption"]</option>
                            </select>
                            <div class="form-text">@Localizer["ParentCategoryHelp"]</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success fw-bold">@Localizer["SaveButton"]</button>
                            <a asp-action="Index" class="btn btn-light border">@Localizer["CancelButton"]</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>