@model UncAds.Models.AttributeDictionary
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["EditDictionaryTitle"];
}

<h2>@Localizer["DictionaryHeader"]</h2>

<form asp-action="Edit" method="post" id="dictForm">
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">@Localizer["NameLabel"]</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <h4>@Localizer["ValuesHeader"]</h4>

    <div id="values-container">
        @if (Model?.Values != null)
        {
            var valuesList = Model.Values.ToList();
            for (int i = 0; i < valuesList.Count; i++)
            {
                <div class="input-group mb-2 value-row">
                    <input type="text"
                           name="Values[@i].Value"
                           value="@valuesList[i].Value"
                           class="form-control js-value-input"
                           placeholder="@Localizer["ValuePlaceholder"]"
                           required />
                    <button type="button" class="btn btn-outline-danger remove-value-btn">@Localizer["RemoveButton"]</button>
                    <input type="hidden" name="Values[@i].Id" value="@valuesList[i].Id" />
                </div>
            }
        }
    </div>

    <div class="mb-3">
        <button type="button" id="add-value-btn" class="btn btn-success btn-sm">
            <i class="bi bi-plus"></i> @Localizer["AddValueButton"]
        </button>
        <div id="error-message" class="text-danger mt-2 fw-bold" style="display:none;">
            @Localizer["ErrorEmptyValue"]
        </div>
    </div>

    <button type="submit" class="btn btn-primary">@Localizer["SaveButton"]</button>
    <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["CancelButton"]</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const container = document.getElementById('values-container');
            const addBtn = document.getElementById('add-value-btn');
            const errorMsg = document.getElementById('error-message');
            const placeholderText = "@Localizer["ValuePlaceholder"]";
            const removeButtonText = "@Localizer["RemoveButton"]";

                    addBtn.addEventListener('click', function () {
            const inputs = container.querySelectorAll('.js-value-input');

            if (inputs.length > 0) {
                const lastInput = inputs[inputs.length - 1];
                if (!lastInput.value || lastInput.value.trim() === "") {
                    errorMsg.style.display = 'block';
                    lastInput.focus();
                    return;
                }
            }
            errorMsg.style.display = 'none';

            const rows = container.querySelectorAll('.value-row');
            const newIndex = rows.length;

            const html = `
                <div class="input-group mb-2 value-row">
                    <input type="text"
                           name="Values[${newIndex}].Value"
                           class="form-control js-value-input"
                           placeholder="${placeholderText}"
                           required />
                    <button type="button" class="btn btn-outline-danger remove-value-btn">${removeButtonText}</button>
                    <input type="hidden" name="Values[${newIndex}].Id" value="0" />
                </div>`;

            container.insertAdjacentHTML('beforeend', html);

            const newInputs = container.querySelectorAll('.js-value-input');
            newInputs[newInputs.length - 1].focus();
        });

            container.addEventListener('click', function (e) {
                if (e.target.classList.contains('remove-value-btn')) {
                    e.target.closest('.value-row').remove();
                    errorMsg.style.display = 'none';
                    reindexInputs();
                }
            });

            function reindexInputs() {
                const rows = container.querySelectorAll('.value-row');
                rows.forEach((row, index) => {
                    const inputName = row.querySelector('input[name^="Values["]');
                    const inputId = row.querySelector('input[name$=".Id"]');

                    if (inputName) {
                        inputName.name = `Values[${index}].Value`;
                    }
                    if (inputId) {
                        inputId.name = `Values[${index}].Id`;
                    }
                });
            }
        });
    </script>
}