@model UncAds.Models.AttributeDictionary
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["CreateDictionaryTitle"];
}

<h2>@Localizer["CreateDictionaryHeader"]</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label">@Localizer["NameLabel"]</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">@Localizer["SaveButton"]</button>
    <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["CancelButton"]</a>
</form>