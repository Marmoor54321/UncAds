@model IEnumerable<UncAds.Models.AttributeDictionary>

@{
    ViewData["Title"] = "Słowniki atrybutów";
}

<h2 class="mb-4">Słowniki atrybutów</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Dodaj nowy słownik
    </a>
</p>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>Nazwa słownika</th>
            <th>Liczba wartości</th>
            <th>Wartości</th>
            <th style="width:180px;">Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var dict in Model)
        {
            <tr>
                <td>@dict.Name</td>
                <td>@(dict.Values?.Count ?? 0)</td>
                <td>
                    @if (dict.Values != null && dict.Values.Any())
                    {
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var val in dict.Values)
                            {
                                <span class="badge bg-secondary">@val.Value</span>
                            }
                        </div>
                    }
                    else
                    {
                        <span class="text-muted fst-italic">brak</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@dict.Id" class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil"></i> Edytuj
                    </a>
                    <a asp-action="Delete" asp-route-id="@dict.Id" class="btn btn-sm btn-danger"
                       onclick="return confirm('Czy na pewno chcesz usunąć ten słownik?');">
                        <i class="bi bi-trash"></i> Usuń
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
