@model IEnumerable<UncAds.Models.AttributeDictionary>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["IndexTitle"];
}

<h2 class="mb-4">@Localizer["IndexHeader"]</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> @Localizer["AddDictionaryButton"]
    </a>
</p>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>@Localizer["Table_Name"]</th>
            <th>@Localizer["Table_ValueCount"]</th>
            <th>@Localizer["Table_Values"]</th>
            <th style="width:180px;">@Localizer["Table_Actions"]</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var dict in Model)
        {
            <tr>
                <td>@dict.Name</td>
                <td>@(dict.Values?.Count ?? 0)</td>
                <td>
                    @if (dict.Values != null && dict.Values.Any())
                    {
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var val in dict.Values)
                            {
                                <span class="badge bg-secondary">@val.Value</span>
                            }
                        </div>
                    }
                    else
                    {
                        <span class="text-muted fst-italic">@Localizer["NoValues"]</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@dict.Id" class="btn btn-sm btn-warning" title="@Localizer["Action_Edit"]">
                        <i class="bi bi-pencil"></i> @Localizer["Action_Edit"]
                    </a>
                    <a asp-action="Delete" asp-route-id="@dict.Id" class="btn btn-sm btn-danger" title="@Localizer["Action_Delete"]"
                       onclick="return confirm('@Localizer["ConfirmDeleteMessage"]');">
                        <i class="bi bi-trash"></i> @Localizer["Action_Delete"]
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>