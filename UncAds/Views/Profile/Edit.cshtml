@model UncAds.Models.ApplicationUser

<h2>Edycja profilu</h2>

<form asp-action="Edit" method="post">

    <div class="mb-3">
        <label class="form-label">Nazwa wyświetlana</label>
        <input asp-for="DisplayName" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Bio</label>
        <textarea asp-for="Bio" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Avatar URL</label>
        <input asp-for="AvatarUrl" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Liczba ogłoszeń na stronie</label>
        <input asp-for="AdsPerPage" type="number" min="1" max="100" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Zapisz</button>

    <h3>Ustawienia Newslettera</h3>
    <p>Wybierz kategorie, z których chcesz otrzymywać powiadomienia:</p>

    <div class="form-group">
        @if (ViewBag.AllCategories != null)
        {
            var selectedIds = ViewBag.SelectedCategoryIds as List<int>;
            foreach (var category in ViewBag.AllCategories as List<UncAds.Models.Category>)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox"
                           name="selectedCategories"
                           value="@category.Id"
                           id="cat_@category.Id"
                           @(selectedIds != null && selectedIds.Contains(category.Id) ? "checked" : "")>
                    <label class="form-check-label" for="cat_@category.Id">
                        @category.Name
                    </label>
                </div>
            }
        }
    </div>
</form>
