@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model UncAds.Models.ApplicationUser

@{
    ViewData["Title"] = Localizer["ProfileTitle"];

    var placeholderText = Localizer["UserPlaceholderText"];
    var avatarSrc = !string.IsNullOrEmpty(Model.AvatarUrl) ? Model.AvatarUrl : $"https://via.placeholder.com/150?text={placeholderText}";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-4">
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body text-center">
                    <img src="@avatarSrc" alt="@Localizer["AvatarAlt"].Value"
                         class="rounded-circle img-fluid border p-1 mb-3" style="width: 150px; height: 150px; object-fit: cover;">

                    <h5 class="my-3">@(Model.DisplayName ?? Localizer["UnnamedUser"].Value)</h5>
                    <p class="text-muted mb-1">@Model.Email</p>

                    <div class="d-flex justify-content-center mb-2 mt-3">
                        <a asp-action="Edit" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-pencil-square"></i> @Localizer["EditProfileButton"]
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="mb-4 text-primary"><i class="bi bi-person-lines-fill"></i> @Localizer["UserInfoHeader"]</h5>

                    <div class="row mb-3">
                        <div class="col-sm-3">
                            <p class="mb-0 fw-bold">@Localizer["DisplayNameLabel"]</p>
                        </div>
                        <div class="col-sm-9">
                            <p class="text-muted mb-0">@Model.DisplayName</p>
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-3">
                            <p class="mb-0 fw-bold">@Localizer["EmailLabel"]</p>
                        </div>
                        <div class="col-sm-9">
                            <p class="text-muted mb-0">@Model.Email</p>
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-3">
                            <p class="mb-0 fw-bold">@Localizer["BioLabel"]</p>
                        </div>
                        <div class="col-sm-9">
                            <p class="text-muted mb-0">
                                @if (string.IsNullOrWhiteSpace(Model.Bio))
                                {
                                    <em class="text-muted small">@Localizer["NoBioMessage"]</em>
                                }
                                else
                                {
                                    @Model.Bio
                                }
                            </p>
                        </div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-3">
                            <p class="mb-0 fw-bold">@Localizer["SettingsLabel"]</p>
                        </div>
                        <div class="col-sm-9">
                            <p class="text-muted mb-0">
                                @Localizer["AdsPerPageSetting", Model.AdsPerPage]
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>