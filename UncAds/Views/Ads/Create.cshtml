@model UncAds.Models.Ad
@{
    ViewBag.Title = "Nowe ogłoszenie";
}

<h2>Nowe ogłoszenie</h2>
<div asp-validation-summary="All" class="text-danger"></div>
<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Tytuł</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group">
        <label>Opis</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Kategorie</label>
        <select id="categorySelect" name="SelectedCategoryIds" multiple class="form-control"
                asp-items="ViewBag.Categories"></select>
    </div>

    <hr />
    <h4>Atrybuty</h4>
    <div id="attributesContainer"></div>

    <button type="submit" class="btn btn-primary">Zapisz</button>
</form>

@section Scripts {
    <script>
        document.getElementById('categorySelect').addEventListener('change', function () {
            const selected = Array.from(this.selectedOptions).map(o => o.value);
            fetch(`/Ads/GetCategoryAttributes?` + new URLSearchParams({ categoryIds: selected }))
                .then(r => r.json())
                .then(data => {
                    const container = document.getElementById('attributesContainer');
                    container.innerHTML = '';
                    data.forEach(attr => {
                        const label = document.createElement('label');
                        label.textContent = attr.name;

                        let input;
                                switch (attr.type) {
            case 0: // Text
                input = document.createElement('input');
                input.type = 'text';
                break;
            case 1: // Number
                input = document.createElement('input');
                input.type = 'number';
                break;
            case 2: // Boolean
                input = document.createElement('input');
                input.type = 'checkbox';
                input.value = 'true';
                break;
            case 3: // Date
                input = document.createElement('input');
                input.type = 'date';
                break;
            case 4: // Select
                input = document.createElement('select');
                const opts = (attr.options ?? '').split(';');
                opts.forEach(o => {
                    if (!o.trim()) return;
                    const opt = document.createElement('option');
                    opt.value = o.trim();
                    opt.textContent = o.trim();
                    input.appendChild(opt);
                });
                break;
        }


                        input.name = `AttributeValues[${attr.id}]`;
                        input.classList.add('form-control');

                        const div = document.createElement('div');
                        div.classList.add('form-group');
                        div.appendChild(label);
                        div.appendChild(input);
                        container.appendChild(div);
                    });
                });
        });
    </script>
}
