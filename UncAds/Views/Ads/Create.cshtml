@model UncAds.Models.Ad
@{
    ViewBag.Title = "Nowe ogłoszenie";
}

<h2>Nowe ogłoszenie</h2>
<div asp-validation-summary="All" class="text-danger"></div>
<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label>Tytuł</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group">
        <label>Opis</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Kategorie</label>
        <select id="categorySelect" name="SelectedCategoryIds" multiple class="form-control"
                asp-items="ViewBag.Categories"></select>
    </div>

    <hr />
    <h4>Atrybuty</h4>
    <div id="attributesContainer"></div>
    <hr />
    <h4>Multimedia</h4>
    <div class="form-group">
        <label>Dodaj pliki (obrazy, dźwięki, Flash)</label>
        <input type="file" name="mediaFiles" multiple class="form-control media-file" accept="video/mp4,image/jpeg,image/png,image/gif,audio/mpeg,audio/wav,audio/ogg,.swf" />
        <small class="text-muted d-block">
            Maks. @ViewBag.MaxMediaFiles plików, każdy do @ViewBag.MaxFileSizeMB MB
        </small>
    </div>
    <hr />
    <h4>Załączniki</h4>
    <div id="attachmentsContainer">
        <div class="attachment-group mb-2">
            <input type="file" name="attachmentFiles" class="form-control mb-1 attachment-file" accept="image/*,audio/*,video/*,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/zip,application/x-rar-compressed,text/plain,text/csv,.swf" />
            <input type="text" name="attachmentDescriptions" placeholder="Opis pliku" class="form-control" />
            <small class="text-muted d-block">Maks. rozmiar: @ViewBag.MaxFileSizeMB MB</small>
        </div>
    </div>
    <button type="button" id="addAttachment" class="btn btn-secondary btn-sm mt-2">+ Dodaj kolejny</button>

    <button type="submit" class="btn btn-primary">Zapisz</button>
</form>

@section Scripts {
    <script>

        const maxAttachments = @ViewBag.MaxAttachments ?? 5;
        const maxFileSizeBytes = @ViewBag.MaxFileSizeMB * 1024 * 1024;
        const container = document.getElementById('attachmentsContainer');
        const addBtn = document.getElementById('addAttachment');
        const maxMediaFiles = @ViewBag.MaxMediaFiles ?? 5;
        const mediaInput = document.querySelector('input[name="mediaFiles"]');

        mediaInput.addEventListener('change', function () {
            if (this.files.length > maxMediaFiles) {
                alert(`Maksymalnie możesz dodać ${maxMediaFiles} plików multimedialnych.`);
                this.value = ''; // wyczyść
            }

            // Walidacja rozmiaru (już masz, ale dla kompletności)
            Array.from(this.files).forEach(file => {
                if (file.size > maxFileSizeBytes) {
                    alert(`Plik "${file.name}" jest za duży! Maks: @ViewBag.MaxFileSizeMB MB.`);
                    this.value = '';
                }
            });
        });
        // Funkcja: walidacja rozmiaru pliku
        function validateFileSize(input) {
            if (!input.files || input.files.length === 0) return true;

            const file = input.files[0];
            if (file.size > maxFileSizeBytes) {
                alert(`Plik "${file.name}" jest za duży! Maksymalny rozmiar: @ViewBag.MaxFileSizeMB MB.`);
                input.value = ''; // wyczyść pole
                return false;
            }
            return true;
        }

        // Funkcja: podpinanie walidacji do inputa
        function attachValidationToFileInput(input) {
            if (!input || input.dataset.validationAttached) return; // unikaj podwójnego podpięcia

            input.addEventListener('change', function () {
                validateFileSize(this);
            });

            input.dataset.validationAttached = 'true'; // oznacz jako podpięte
        }

        // === INICJALIZACJA: podłącz walidację do WSZYSTKICH istniejących pól ===
        document.querySelectorAll('.attachment-file').forEach(attachValidationToFileInput);

        // === DODAWANIE NOWEGO ZAŁĄCZNIKA ===
        addBtn.addEventListener('click', function () {
            const currentCount = container.querySelectorAll('.attachment-group').length;
            if (currentCount >= maxAttachments) {
                alert(`Nie możesz dodać więcej niż ${maxAttachments} załączników.`);
                return;
            }

            const div = document.createElement('div');
            div.classList.add('attachment-group', 'mb-2');
            div.innerHTML = `
                <input type="file" name="attachmentFiles" class="form-control mb-1 attachment-file" />
                <input type="text" name="attachmentDescriptions" placeholder="Opis pliku" class="form-control" />
                <small class="text-muted d-block">Maks. rozmiar: @ViewBag.MaxFileSizeMB MB</small>
                <button type="button" class="btn btn-danger btn-sm mt-1 remove-attachment">Usuń</button>
            `;
            container.appendChild(div);

            // Podłącz walidację do NOWEGO inputa
            const newFileInput = div.querySelector('.attachment-file');
            attachValidationToFileInput(newFileInput);

            // Usuwanie załącznika
            div.querySelector('.remove-attachment').addEventListener('click', function () {
                div.remove();
            });
        });

        // === OPCJONALNIE: Walidacja multimediów (jeśli chcesz) ===
        document.querySelectorAll('.media-file').forEach(input => {
            input.addEventListener('change', function () {
                Array.from(this.files).forEach(file => {
                    if (file.size > maxFileSizeBytes) {
                        alert(`Plik multimedialny "${file.name}" jest za duży!`);
                        this.value = ''; // wyczyść całe pole
                    }
                });
            });
        });
    </script>
    <script>

        
        document.getElementById('categorySelect').addEventListener('change', function () {
            const selected = Array.from(this.selectedOptions).map(o => o.value);
            fetch(`/Ads/GetCategoryAttributes?` + new URLSearchParams({ categoryIds: selected }))
                .then(r => r.json())
                .then(data => {
                    const container = document.getElementById('attributesContainer');
                    container.innerHTML = '';
                    data.forEach(attr => {
                        const label = document.createElement('label');
                        label.textContent = attr.name;

                        let input;
                                switch (attr.type) {
            case 0: // Text
                input = document.createElement('input');
                input.type = 'text';
                break;
            case 1: // Number
                input = document.createElement('input');
                input.type = 'number';
                break;
            case 2: // Boolean
                input = document.createElement('select');
                const trueOpt = document.createElement('option');
                trueOpt.value = 'true';
                trueOpt.textContent = 'Tak';
                const falseOpt = document.createElement('option');
                falseOpt.value = 'false';
                falseOpt.textContent = 'Nie';
                input.appendChild(trueOpt);
                input.appendChild(falseOpt);
        break;
            case 3: // Date
                input = document.createElement('input');
                input.type = 'date';
                break;
            case 4: // Select
                input = document.createElement('select');
                const opts = (attr.options ?? '').split(';');
                opts.forEach(o => {
                    if (!o.trim()) return;
                    const opt = document.createElement('option');
                    opt.value = o.trim();
                    opt.textContent = o.trim();
                    input.appendChild(opt);
                });
                break;
        }


                        input.name = `AttributeValues[${attr.id}]`;
                        input.classList.add('form-control');

                        const div = document.createElement('div');
                        div.classList.add('form-group');
                        div.appendChild(label);
                        div.appendChild(input);
                        container.appendChild(div);
                    });
                });
        });
    </script>
}
