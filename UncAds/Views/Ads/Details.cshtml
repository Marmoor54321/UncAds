@model UncAds.Models.Ad
@{
    ViewBag.Title = Model.Title;
}

<h2>@Model.Title</h2>
@Html.Raw(Model.Description)

@if (Model.Media != null && Model.Media.Any())
{
    <hr />
    <h4>Multimedia</h4>
    <div>
        @foreach (var m in Model.Media)
        {
            if (m.MediaType == "image")
            {
                <img src="@m.FilePath" alt="obraz" style="max-width:300px; margin:10px;" />
            }
            else if (m.MediaType == "audio")
            {
                <audio controls style="display:block; margin:10px;">
                    <source src="@m.FilePath" type="audio/mpeg" />
                    Twoja przeglądarka nie obsługuje odtwarzania audio.
                </audio>
            }
            else if (m.MediaType == "video")
            {
                <video controls class="w-100 mb-2" style="max-height: 400px;">
                    <source src="@m.FilePath" type="video/mp4">
                    Twoja przeglądarka nie obsługuje wideo.
                </video>
            }
            else if (m.MediaType == "flash")
            {
                <object data="@m.FilePath" type="application/x-shockwave-flash" width="400" height="300"></object>
            }
        }
    </div>
}
@if (Model.Attachments != null && Model.Attachments.Any())
{
    <hr />
    <h4>Załączniki</h4>
    <ul>
        @foreach (var a in Model.Attachments)
        {
            <li>
                <a href="@a.FilePath" target="_blank">@System.IO.Path.GetFileName(a.FilePath)</a>
                @if (!string.IsNullOrEmpty(a.Description))
                {
                    <span> — @a.Description</span>
                }
            </li>
        }
    </ul>
}


    <p><strong>Date:</strong> @Model.Date.ToString("g")</p>
    <p><strong>Author:</strong> @Model.User?.UserName</p>

    <h5>Kategorie:</h5>
    @if (Model.AdCategories != null && Model.AdCategories.Any())
    {
        <ul class="category-tree list-unstyled">
            @foreach (var ac in Model.AdCategories)
            {
                <li>
                    <i class="bi bi-folder"></i> @ac.Category.FullPath
                </li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted">Brak przypisanych kategorii</p>
    }
    @if (Model.AttributeValues != null && Model.AttributeValues.Any())
    {
        <h5>Atrybuty:</h5>
        <ul>
            @foreach (var av in Model.AttributeValues)
            {
                <li><strong>@av.CategoryAttribute.Name:</strong> @av.Value</li>
            }
        </ul>
    }

</div>

<p>
    @if (Model.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value || User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</p>

<style>
    .category-tree {
        padding-left: 0.5rem;
        border-left: 2px solid #ccc;
        margin-bottom: 1rem;
    }

        .category-tree li {
            margin: 4px 0;
            padding-left: 0.5rem;
            font-size: 1rem;
        }

        .category-tree i {
            color: #f0ad4e;
            margin-right: 6px;
        }
</style>