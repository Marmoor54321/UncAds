@model UncAds.Models.Ad

<h2>Edit Ad</h2>
<div asp-validation-summary="All" class="text-danger"></div>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Categories</label>
        <select name="SelectedCategoryIds" multiple class="form-control" asp-items="ViewBag.Categories"></select>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>

    <hr />
<h4>Atrybuty</h4>
<div id="attributesContainer">
    @if (ViewBag.Attributes != null)
    {
        foreach (var attr in (List<UncAds.Models.CategoryAttribute>)ViewBag.Attributes)
        {
            var existingValue = Model.AttributeValues?
                .FirstOrDefault(v => v.CategoryAttributeId == attr.Id)?.Value ?? "";

            <div class="form-group">
                <label>@attr.Name</label>

                @if (attr.Type == UncAds.Models.AttributeType.Select)
                {
                    var opts = (attr.Options ?? "").Split(';', StringSplitOptions.RemoveEmptyEntries);
                    <select name="AttributeValues[@attr.Id]" class="form-control">
                        @foreach (var o in opts)
                        {
                                <option value="@o" selected="@(existingValue == o)">@o</option>
                        }
                    </select>
                }
                    else if (attr.Type == UncAds.Models.AttributeType.Boolean)
                    {
                        <select name="AttributeValues[@attr.Id]" class="form-control">
                            <option value="true" selected="@(existingValue == "true")">Tak</option>
                            <option value="false" selected="@(existingValue == "false")">Nie</option>
                        </select>
                    }
                else if (attr.Type == UncAds.Models.AttributeType.Number)
                {
                    <input type="number" name="AttributeValues[@attr.Id]" value="@existingValue" class="form-control" />
                }
                else if (attr.Type == UncAds.Models.AttributeType.Date)
                {
                    <input type="date" name="AttributeValues[@attr.Id]" value="@existingValue" class="form-control" />
                }
                else
                {
                    <input type="text" name="AttributeValues[@attr.Id]" value="@existingValue" class="form-control" />
                }
            </div>
        }
    }
</div>

</form>
