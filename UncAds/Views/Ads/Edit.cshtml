@model UncAds.Models.Ad
@using System.Text.Json
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["EditAdTitle"];

    var sourceData = Model.AttributeValues != null
        ? Model.AttributeValues.Select(av => (object)new { id = av.CategoryAttributeId, val = av.Value })
        : Array.Empty<object>();

    var existingValuesJson = JsonSerializer.Serialize(sourceData);

    var jsLocalizations = JsonSerializer.Serialize(new
    {
        ChooseCategory = Localizer["ChooseCategoryMessage"].Value,
        NoAttributes = Localizer["NoAttributesMessage"].Value,
        LoadingError = Localizer["AttributeLoadingError"].Value,
        SelectOption = Localizer["SelectOptionDefault"].Value,
        BooleanYes = Localizer["BooleanOptionYes"].Value,
        BooleanNo = Localizer["BooleanOptionNo"].Value
    });
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="m-0"><i class="bi bi-pencil-square"></i> @Localizer["EditAdHeader"]</h2>
            </div>

            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="m-0 text-primary"><i class="bi bi-card-text"></i> @Localizer["AdDataHeader"]</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label asp-for="Title" class="form-label fw-bold">@Localizer["TitleLabel"]</label>
                                <input asp-for="Title" class="form-control" />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">@Localizer["CategoriesLabel"]</label>
                                <select id="categorySelect" name="SelectedCategoryIds" multiple class="form-select" style="height: 50px;" asp-items="ViewBag.Categories"></select>
                                <div class="form-text small">@Localizer["CategorySelectHelp"]</div>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-bold">@Localizer["DescriptionLabel"]</label>
                                <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="m-0 text-primary"><i class="bi bi-sliders"></i> @Localizer["AttributesHeader"]</h5>
                    </div>
                    <div class="card-body p-4">
                        <div id="attributesContainer">
                            <div class="text-center py-3"><div class="spinner-border text-primary" role="status"></div></div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mb-5">
                    <a asp-action="Index" class="btn btn-light border px-4">@Localizer["CancelButton"]</a>
                    <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">@Localizer["SaveChangesButton"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .validation-summary-valid {
        display: none;
    }
</style>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const categorySelect = document.getElementById('categorySelect');
            const attributesContainer = document.getElementById('attributesContainer');

            const loc = @Html.Raw(jsLocalizations);

            const savedValues = @Html.Raw(existingValuesJson);

            function isValueSelected(attrId, valueToCheck) {
                return savedValues.some(item => item.id === attrId && item.val == valueToCheck);
            }

            function getSavedValue(attrId) {
                const found = savedValues.find(item => item.id === attrId);
                return found ? found.val : "";
            }

            function loadAttributes() {
                const selected = Array.from(categorySelect.selectedOptions).map(o => o.value);

                if(selected.length === 0) {
                    attributesContainer.innerHTML = '<p class="text-muted text-center fst-italic">' + loc.ChooseCategory + '</p>';
                    return;
                }

                attributesContainer.innerHTML = '<div class="text-center py-3"><div class="spinner-border text-primary" role="status"></div></div>';

                const params = new URLSearchParams();
                selected.forEach(id => params.append('categoryIds', id));

                fetch(`/Ads/GetCategoryAttributes?` + params.toString())
                    .then(r => r.json())
                    .then(data => {
                        attributesContainer.innerHTML = '';

                        if(data.length === 0){
                            attributesContainer.innerHTML = '<p class="text-muted text-center">' + loc.NoAttributes + '</p>';
                            return;
                        }

                        const rowDiv = document.createElement('div');
                        rowDiv.classList.add('row', 'g-3');
                        attributesContainer.appendChild(rowDiv);

                        data.forEach(attr => {
                            const colDiv = document.createElement('div');
                            colDiv.classList.add('col-md-6');

                            const label = document.createElement('label');
                            label.textContent = attr.name;
                            label.classList.add('form-label', 'fw-bold', 'small');

                            let input;

                            switch (attr.type) {
                                case 0: // Text
                                    input = document.createElement('input');
                                    input.type = 'text';
                                    input.classList.add('form-control');
                                    input.value = getSavedValue(attr.id);
                                    break;
                                case 1: // Number
                                    input = document.createElement('input');
                                    input.type = 'number';
                                    input.classList.add('form-control');
                                    input.value = getSavedValue(attr.id);
                                    break;
                                case 2: // Boolean
                                    input = document.createElement('select');
                                    input.classList.add('form-select');
                                    input.innerHTML = `
                                        <option value="true" ${isValueSelected(attr.id, 'true') ? 'selected' : ''}>${loc.BooleanYes}</option>
                                        <option value="false" ${isValueSelected(attr.id, 'false') ? 'selected' : ''}>${loc.BooleanNo}</option>
                                    `;
                                    break;
                                case 3: // Date
                                    input = document.createElement('input');
                                    input.type = 'date';
                                    input.classList.add('form-control');
                                    let dVal = getSavedValue(attr.id);
                                    if(dVal) {
                                        try {
                                            let d = new Date(dVal);
                                            if(!isNaN(d)) input.value = d.toISOString().split('T')[0];
                                        } catch(e){}
                                    }
                                    break;
                                case 4: // Select
                                    input = document.createElement('select');
                                    input.classList.add('form-select');
                                    if (attr.options) {
                                        attr.options.split(';').forEach(o => {
                                            if(o.trim()){
                                                const opt = document.createElement('option');
                                                opt.value = o.trim();
                                                opt.textContent = o.trim();
                                                if(isValueSelected(attr.id, o.trim())) opt.selected = true;
                                                input.appendChild(opt);
                                            }
                                        });
                                    }
                                    break;
                                case 5: // Dictionary
                                    input = document.createElement('select');
                                    input.classList.add('form-select');
                                    if (attr.allowMultiple) input.multiple = true;

                                    if(!attr.allowMultiple) {
                                        let emptyOpt = document.createElement('option');
                                        emptyOpt.value = "";
                                        emptyOpt.textContent = loc.SelectOption;
                                        input.appendChild(emptyOpt);
                                    }

                                    if (attr.dictionaryValues) {
                                        attr.dictionaryValues.forEach(v => {
                                            const opt = document.createElement('option');
                                            opt.value = v;
                                            opt.textContent = v;
                                            if(isValueSelected(attr.id, v)) opt.selected = true;
                                            input.appendChild(opt);
                                        });
                                    }
                                    break;
                            }

                            input.name = `AttributeValues[${attr.id}]`;

                            colDiv.appendChild(label);
                            colDiv.appendChild(input);
                            rowDiv.appendChild(colDiv);
                        });
                    })
                    .catch(err => {
                        console.error(err);
                        attributesContainer.innerHTML = '<div class="alert alert-danger">' + loc.LoadingError + '</div>';
                    });
            }

            categorySelect.addEventListener('change', loadAttributes);

            loadAttributes();
        });
    </script>
}