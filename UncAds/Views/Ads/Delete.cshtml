@model UncAds.Models.Ad

@{
    ViewData["Title"] = "Usuń ogłoszenie";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h3 class="m-0"><i class="bi bi-exclamation-triangle-fill"></i> Potwierdź usunięcie</h3>
                </div>
                <div class="card-body p-4 text-center">

                    <h5 class="card-title text-danger mb-3">Czy na pewno chcesz usunąć to ogłoszenie?</h5>
                    <p class="text-muted mb-4">Tej operacji nie można cofnąć. Wszystkie zdjęcia i załączniki również zostaną usunięte.</p>

                    <div class="bg-light p-3 rounded border mb-4 text-start">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-secondary">Tytuł:</dt>
                            <dd class="col-sm-8 fw-bold text-dark">@Html.DisplayFor(model => model.Title)</dd>

                            <dt class="col-sm-4 text-secondary">Data dodania:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.Date)</dd>

                            <dt class="col-sm-4 text-secondary">Kategorie:</dt>
                            <dd class="col-sm-8">
                                @if (Model.AdCategories != null && Model.AdCategories.Any())
                                {
                                    @foreach (var ac in Model.AdCategories)
                                    {
                                        <span class="badge bg-secondary me-1">@ac.Category.Name</span>
                                    }
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </dd>
                        </dl>
                    </div>

                    <form asp-action="Delete" class="d-flex justify-content-center gap-3">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Anuluj</a>
                        <button type="submit" class="btn btn-danger px-4 fw-bold">Tak, usuń trwale</button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>