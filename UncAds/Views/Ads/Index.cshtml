@model IEnumerable<UncAds.Models.Ad>

@{
    ViewData["Title"] = "Ogłoszenia";

    // Pobieramy listy z ViewBag
    var displayCategories = ViewBag.DisplayCategories as List<UncAds.Models.Category>;
    var currentCategory = ViewBag.CurrentCategory as UncAds.Models.Category;

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string currentQuery = ViewBag.Query as string;
    int? currentCategoryId = ViewBag.SelectedCategoryId as int?;
}

<style>
    .cat-card {
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
        border: 1px solid #dee2e6;
    }

        .cat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
            background-color: #f8f9fa;
            border-color: #0d6efd;
        }

    .cat-icon {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
        color: #6c757d;
    }

    .breadcrumb-custom a {
        text-decoration: none;
        color: #0d6efd;
    }

    .breadcrumb-custom span {
        color: #6c757d;
    }
</style>

<div class="container mt-4">

    <div class="row mb-4">
        <div class="col-12">
            <div class="p-4 bg-light rounded shadow-sm border">
                <form asp-action="Index" method="get">
                    <div class="row g-2">
                        <div class="col-md-4">
                            <select name="categoryId" class="form-select" asp-items="ViewBag.SearchCategories" onchange="this.form.submit()">
                                <option value="">-- Wszystkie działy --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <input type="text" name="query" class="form-control"
                                   placeholder="Szukaj: auto, praca..."
                                   value="@currentQuery" />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100 fw-bold">Szukaj</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (currentCategory != null)
    {
        <div class="mb-3">
            <div class="d-flex align-items-center breadcrumb-custom">
                @if (currentCategory.ParentCategoryId != null)
                {
                    // Przycisk powrotu do rodzica
                    <a href="@Url.Action("Index", new { categoryId = currentCategory.ParentCategoryId, query = currentQuery })" class="btn btn-outline-secondary btn-sm me-2">
                        <i class="bi bi-arrow-left"></i> Wróć do @currentCategory.ParentCategory?.Name
                    </a>
                }
                else
                {
                    // Przycisk powrotu do strony głównej (Wszystkie)
                    <a href="@Url.Action("Index", new { categoryId = "", query = currentQuery })" class="btn btn-outline-secondary btn-sm me-2">
                        <i class="bi bi-arrow-left"></i> Wszystkie działy
                    </a>
                }

                <span class="ms-2 fs-5">
                    Przeglądasz: <strong>@currentCategory.Name</strong>
                </span>
            </div>
        </div>
    }
    else
    {
        <h4 class="text-center mb-4 text-muted">Kategorie główne</h4>
    }

    @if (displayCategories != null && displayCategories.Any())
    {
        <div class="row mb-5 justify-content-center">
            @foreach (var cat in displayCategories)
            {
                // Sprawdzamy, czy to jest ta aktualnie kliknięta kategoria
                bool isActive = currentCategoryId == cat.Id;

                // Klasy stylów:
                // Aktywny: niebieskie tło, biały tekst, cień
                // Zwykły: białe tło, ciemny tekst
                string cardClass = isActive
                ? "bg-primary text-white shadow border-primary"
                : "bg-white text-dark";

                <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-3">
                    <a href="@Url.Action("Index", new { categoryId = cat.Id, query = currentQuery })"
                       class="card h-100 text-decoration-none cat-card @cardClass">

                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-3">
                            <div class="cat-icon mb-2">
                                @if (isActive)
                                {
                                    // Ikona dla wybranego elementu (np. "ptaszek")
                                    <i class="bi bi-check-circle-fill fs-3"></i>
                                }
                                else
                                {
                                    // Ikona dla rodzeństwa/dzieci
                                    <span class="fs-3">📂</span>
                                }
                            </div>

                            <span class="small fw-bold">@cat.Name</span>
                        </div>
                    </a>
                </div>
            }
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Dodaj ogłoszenie
            </a>
        </div>

        @if (!string.IsNullOrEmpty(currentQuery) || currentCategoryId.HasValue)
        {
            <div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Wyczyść filtry</a>
            </div>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead class="table-light">
                <tr>
                    <th>Tytuł</th>
                    <th>Opis</th>
                    <th>Data</th>
                    <th>Kategorie</th>
                    <th>Szczegóły</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <h4>Brak ogłoszeń w tej kategorii.</h4>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@item.Title</div>
                                @if (item.Media != null && item.Media.Any())
                                {
                                    <span class="badge bg-info text-dark" style="font-size: 0.7em">FOTO</span>
                                }
                            </td>
                            <td>
                                @{
                                    var desc = item.Description;
                                    if (!string.IsNullOrEmpty(desc) && desc.Length > 50) desc = desc.Substring(0, 50) + "...";
                                }
                                <span class="text-muted">@Html.Raw(desc)</span>
                            </td>
                            <td style="white-space: nowrap;">@item.Date.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (item.AdCategories != null)
                                {
                                    foreach (var ac in item.AdCategories)
                                    {
                                        <span class="badge bg-secondary me-1">@ac.Category.Name</span>
                                    }
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Zobacz</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = currentPage - 1, query = currentQuery, categoryId = currentCategoryId })">Poprzednia</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(currentPage == i ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = i, query = currentQuery, categoryId = currentCategoryId })">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = currentPage + 1, query = currentQuery, categoryId = currentCategoryId })">Następna</a>
                </li>
            </ul>
        </nav>
    }
</div>