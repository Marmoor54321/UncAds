@model IEnumerable<UncAds.Models.Ad>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>
<p>Zalogowany użytkownik: @User?.Identity?.Name</p>
<p>Rola Admin: @User.IsInRole("Admin")</p>


<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Title)</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>@Html.DisplayNameFor(model => model.Date)</th>
            <th>Categories</th>
            <th>Author</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Description</td>
                <td>@item.Date.ToString("g")</td>

                <td>
                    @if (item.AdCategories != null && item.AdCategories.Any())
                    {
                        <ul class="list-unstyled">
                            @foreach (var ac in item.AdCategories)
                            {
                                <li>@ac.Category.Name</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span class="text-muted">No categories</span>
                    }
                </td>

                <td>@item.User?.UserName</td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    @if (item.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value || User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
