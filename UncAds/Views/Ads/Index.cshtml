@model IEnumerable<UncAds.Models.Ad>

@{
    ViewData["Title"] = "Ogłoszenia";

    // Pobieramy listy z ViewBag
    var displayCategories = ViewBag.DisplayCategories as List<UncAds.Models.Category>;
    var currentCategory = ViewBag.CurrentCategory as UncAds.Models.Category;

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string currentQuery = ViewBag.Query as string;
    int? currentCategoryId = ViewBag.SelectedCategoryId as int?;
}

<style>
    .cat-card {
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
        border: 1px solid #dee2e6;
    }

        .cat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
            background-color: #f8f9fa;
            border-color: #0d6efd;
        }

    .cat-icon {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
        color: #6c757d;
    }

    .breadcrumb-custom a {
        text-decoration: none;
        color: #0d6efd;
    }

    .breadcrumb-custom span {
        color: #6c757d;
    }
</style>

<div class="container mt-4">

    <div class="row mb-4">
        <div class="col-12">
            <div class="p-4 bg-light rounded shadow-sm border">
                <form asp-action="Index" method="get">

                    @if (ViewBag.AttributeFilters is Dictionary<int, string> activeFilters && activeFilters.Any())
                    {
                        foreach (var filter in activeFilters)
                        {
                            <input type="hidden" name="attributeFilters[@filter.Key]" value="@filter.Value" />
                        }
                    }
                    <div class="row g-2">
                        <div class="col-md-4">
                            <select name="categoryId" class="form-select" asp-items="ViewBag.SearchCategories" onchange="this.form.submit()">
                                <option value="">-- Wszystkie działy --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <input type="text" name="query" class="form-control"
                                   placeholder="Szukaj: auto, praca..."
                                   value="@currentQuery" />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100 fw-bold">Szukaj</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (currentCategory != null)
    {
        <div class="mb-3">
            <div class="d-flex align-items-center breadcrumb-custom">
                @if (currentCategory.ParentCategoryId != null)
                {
                    <a href="@Url.Action("Index", new { categoryId = currentCategory.ParentCategoryId, query = currentQuery })" class="btn btn-outline-secondary btn-sm me-2">
                        <i class="bi bi-arrow-left"></i> Wróć do @currentCategory.ParentCategory?.Name
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Index", new { categoryId = "", query = currentQuery })" class="btn btn-outline-secondary btn-sm me-2">
                        <i class="bi bi-arrow-left"></i> Wszystkie działy
                    </a>
                }
                <span class="ms-2 fs-5">Przeglądasz: <strong>@currentCategory.Name</strong></span>
            </div>
        </div>
    }

    @{
        bool showAttributes = ViewBag.ShowAttributes ?? false;
        var attributes = ViewBag.AttributesToDisplay as List<UncAds.Models.CategoryAttribute>;
        var activeFilters = ViewBag.AttributeFilters as Dictionary<int, string>;
    }

    @if (showAttributes && attributes != null && attributes.Any())
    {
        <div class="card mb-4 border-primary shadow-sm bg-light">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="bi bi-sliders"></i> Szczegółowe filtry dla kategorii @currentCategory.Name
            </div>
            <div class="card-body">
                <form asp-action="Index" method="get">
                    <input type="hidden" name="query" value="@currentQuery" />
                    <input type="hidden" name="categoryId" value="@currentCategoryId" />

                    <div class="row g-3">
                        @foreach (var attr in attributes)
                        {
                            string currentValue = "";
                            if (activeFilters != null && activeFilters.ContainsKey(attr.Id))
                            {
                                currentValue = activeFilters[attr.Id];
                            }

                            <div class="col-md-3">
                                <label class="form-label small fw-bold">@attr.Name</label>

                                @if (attr.Type == UncAds.Models.AttributeType.Dictionary && attr.Dictionary != null)
                                {
                                    // SŁOWNIK
                                    <select name="attributeFilters[@attr.Id]" class="form-select form-select-sm">
                                        <option value="">- Wszystkie -</option>
                                        @foreach (var val in attr.Dictionary.Values)
                                        {
                                            <!option value="@val.Value" @(currentValue == val.Value ? "selected" : "")>@val.Value</!option>
                                        }
                                    </select>
                                }
                                else if (attr.Type == UncAds.Models.AttributeType.Select && !string.IsNullOrEmpty(attr.Options))
                                {
                                    // SELECT (z pola Options, np. csv)
                                    var opts = attr.Options.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                    <select name="attributeFilters[@attr.Id]" class="form-select form-select-sm">
                                        <option value="">- Wszystkie -</option>
                                        @foreach (var opt in opts)
                                        {
                                            var cleanOpt = opt.Trim();
                                            <!option value="@cleanOpt" @(currentValue == cleanOpt ? "selected" : "")>@cleanOpt</!option>
                                        }
                                    </select>
                                }
                                else if (attr.Type == UncAds.Models.AttributeType.Boolean)
                                {
                                    // BOOLEAN
                                    <select name="attributeFilters[@attr.Id]" class="form-select form-select-sm">
                                        <option value="">- Nieistotne -</option>
                                        <!option value="true" @(currentValue == "true" ? "selected" : "")>Tak</!option>
                                        <!option value="false" @(currentValue == "false" ? "selected" : "")>Nie</!option>
                                    </select>
                                }
                                else if (attr.Type == UncAds.Models.AttributeType.Number)
                                {
                                    // NUMBER
                                    // (Tutaj proste wyszukiwanie dokładne, w przyszłości można zrobić Zakres Od-Do)
                                    <input type="number" name="attributeFilters[@attr.Id]" class="form-control form-control-sm" value="@currentValue" placeholder="Wpisz wartość..." />
                                }
                                else if (attr.Type == UncAds.Models.AttributeType.Date)
                                {
                                    // DATE
                                    <input type="date" name="attributeFilters[@attr.Id]" class="form-control form-control-sm" value="@currentValue" />
                                }
                                else
                                {
                                    // TEXT / INNE
                                    <input type="text" name="attributeFilters[@attr.Id]" class="form-control form-control-sm" value="@currentValue" placeholder="..." />
                                }
                            </div>
                        }

                        <div class="col-md-12 d-flex justify-content-end mt-3 border-top pt-2">
                            <a href="@Url.Action("Index", new { categoryId = currentCategoryId, query = currentQuery })" class="btn btn-outline-secondary btn-sm me-2">Wyczyść filtry</a>
                            <button type="submit" class="btn btn-primary btn-sm px-4">Filtruj</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
    else
    {
        @if (displayCategories != null && displayCategories.Any())
        {
            <div class="row mb-5 justify-content-center">
                @foreach (var cat in displayCategories)
                {
                    bool isActive = currentCategoryId == cat.Id;
                    string cardClass = isActive ? "bg-primary text-white shadow border-primary" : "bg-white text-dark";

                    <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-3">
                        <a href="@Url.Action("Index", new { categoryId = cat.Id, query = currentQuery })"
                           class="card h-100 text-decoration-none cat-card @cardClass">
                            <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-3">
                                <div class="cat-icon mb-2">
                                    @if (isActive)
                                    {
                                        <i class="bi bi-check-circle-fill fs-3"></i>
                                    }
                                    else
                                    {

                                        <span class="fs-3">📂</span>
                                    }
                                </div>
                                <span class="small fw-bold">@cat.Name</span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Dodaj ogłoszenie
            </a>
        </div>

        @if (!string.IsNullOrEmpty(currentQuery) || currentCategoryId.HasValue)
        {
            <div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Wyczyść filtry</a>
            </div>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead class="table-light">
                <tr>
                    <th>Tytuł</th>
                    <th>Opis</th>
                    <th>Data</th>
                    <th>Kategorie</th>
                    <th>Szczegóły</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <h4>Brak ogłoszeń w tej kategorii.</h4>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@item.Title</div>
                                @if (item.Media != null && item.Media.Any())
                                {
                                    <span class="badge bg-info text-dark" style="font-size: 0.7em">FOTO</span>
                                }
                            </td>
                            <td>
                                @{
                                    var desc = item.Description;
                                    if (!string.IsNullOrEmpty(desc) && desc.Length > 50) desc = desc.Substring(0, 50) + "...";
                                }
                                <span class="text-muted">@Html.Raw(desc)</span>
                            </td>
                            <td style="white-space: nowrap;">@item.Date.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (item.AdCategories != null)
                                {
                                    foreach (var ac in item.AdCategories)
                                    {
                                        <span class="badge bg-secondary me-1">@ac.Category.Name</span>
                                    }
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Zobacz</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = currentPage - 1, query = currentQuery, categoryId = currentCategoryId })">Poprzednia</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(currentPage == i ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = i, query = currentQuery, categoryId = currentCategoryId })">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = currentPage + 1, query = currentQuery, categoryId = currentCategoryId })">Następna</a>
                </li>
            </ul>
        </nav>
    }
</div>