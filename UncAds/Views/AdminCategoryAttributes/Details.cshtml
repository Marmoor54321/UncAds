@model UncAds.Models.CategoryAttribute
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["DetailsAttributeTitle"];
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h5 class="m-0"><i class="bi bi-info-circle"></i> @Localizer["DetailsAttributeHeader"]</h5>
                    <span class="badge bg-primary">@Localizer["IdLabel"]: @Model.Id</span>
                </div>
                <div class="card-body p-4">

                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th class="text-muted w-25">@Localizer["NameLabel"]:</th>
                                <td class="fw-bold fs-5">@Model.Name</td>
                            </tr>
                            <tr>
                                <th class="text-muted">@Localizer["CategoryLabel"]:</th>
                                <td><span class="badge bg-light text-dark border"><i class="bi bi-folder"></i> @Model.Category.Name</span></td>
                            </tr>
                            <tr>
                                <th class="text-muted">@Localizer["TypeLabel"]:</th>
                                <td><code>@Model.Type</code></td>
                            </tr>
                            <tr>
                                <th class="text-muted">@Localizer["AllowMultipleLabel"]:</th>
                                <td>
                                    @if (Model.AllowMultiple)
                                    {
                                        <span class="text-success fw-bold"><i class="bi bi-check-circle"></i> @Localizer["Yes"]</span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary"><i class="bi bi-x-circle"></i> @Localizer["No"]</span>
                                    }
                                </td>
                            </tr>

                            @if (!string.IsNullOrEmpty(Model.Options))
                            {
                                <tr>
                                    <th class="text-muted align-top">@Localizer["OptionsLabel"]:</th>
                                    <td>
                                        @foreach (var opt in Model.Options.Split(';', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <span class="badge bg-secondary me-1">@opt</span>
                                        }
                                    </td>
                                </tr>
                            }

                            <tr>
                                <th class="text-muted align-top">@Localizer["DictionaryLabel"]:</th>
                                <td>
                                    @if (Model.Dictionary != null)
                                    {
                                        <div class="fw-bold mb-1"><i class="bi bi-book"></i> @Model.Dictionary.Name</div>
                                        @if (Model.Dictionary.Values != null && Model.Dictionary.Values.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                @foreach (var v in Model.Dictionary.Values.Take(10))
                                                {
                                                    <span class="badge bg-light text-secondary border">@v.Value</span>
                                                }
                                                @if (Model.Dictionary.Values.Count > 10)
                                                {
                                                    <span class="badge bg-light text-muted border">...</span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <em class="small text-muted">@Localizer["DictionaryEmpty"]</em>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-center gap-2 mt-4">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">@Localizer["EditButton"]</a>
                        <a asp-action="Index" class="btn btn-secondary px-4">@Localizer["BackButton"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>