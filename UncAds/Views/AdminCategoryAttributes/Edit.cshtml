@model UncAds.Models.CategoryAttribute
@{
    ViewData["Title"] = "Edytuj atrybut";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="m-0 text-primary"><i class="bi bi-pencil-square"></i> Edytuj atrybut</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Nazwa atrybutu</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Type" class="form-label fw-bold">Typ pola</label>
                                <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<UncAds.Models.AttributeType>()"></select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Kategoria</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories"></select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Options" class="form-label fw-bold">Opcje wyboru (Select)</label>
                            <input asp-for="Options" class="form-control" />
                            <div class="form-text">Wartości rozdzielone średnikiem (;).</div>
                        </div>

                        <div class="mb-3 bg-light p-3 rounded border">
                            <div class="mb-3">
                                <label class="form-label">Słownik zewnętrzny</label>
                                <select asp-for="DictionaryId" class="form-select" asp-items="ViewBag.Dictionaries">
                                    <option value="">— brak —</option>
                                </select>
                            </div>

                            <div class="form-check form-switch">
                                <input asp-for="AllowMultiple" class="form-check-input" type="checkbox" />
                                <label asp-for="AllowMultiple" class="form-check-label">Pozwól na wiele wartości</label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-light border px-4">Anuluj</a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Zapisz zmiany</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>