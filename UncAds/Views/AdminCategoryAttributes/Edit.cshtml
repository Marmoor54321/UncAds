@model UncAds.Models.CategoryAttribute
@{
    ViewData["Title"] = "Edytuj atrybut";
}

<h2>Edytuj atrybut</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Type"></label>
        <select asp-for="Type" class="form-control" asp-items="Html.GetEnumSelectList<UncAds.Models.AttributeType>()"></select>
    </div>

    <div class="form-group">
        <label asp-for="Options">Opcje (dla Select)</label>
        <input asp-for="Options" class="form-control" />
    </div>

    <div class="form-group">
        <label>Kategoria</label>
        <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.Categories"></select>
    </div>

    <div class="form-group">
        <label>Słownik (opcjonalny)</label>
        <select asp-for="DictionaryId" class="form-control" asp-items="ViewBag.Dictionaries">
            <option value="">— brak —</option>
        </select>
    </div>

    <div class="form-check mb-3">
        <input asp-for="AllowMultiple" class="form-check-input" type="checkbox" />
        <label asp-for="AllowMultiple" class="form-check-label">Pozwól na wiele wartości</label>
    </div>

    <button type="submit" class="btn btn-primary">Zapisz zmiany</button>
    <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
</form>
