@model UncAds.Models.CategoryAttribute
@{
    ViewData["Title"] = "Nowy atrybut";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="m-0 text-success"><i class="bi bi-plus-square"></i> Nowy atrybut kategorii</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger mb-3" style="display:none"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Nazwa atrybutu</label>
                            <input asp-for="Name" class="form-control" placeholder="np. Rok produkcji, Kolor, Przebieg" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Type" class="form-label fw-bold">Typ pola</label>
                                <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<UncAds.Models.AttributeType>()"></select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Przypisz do kategorii</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories"></select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Options" class="form-label fw-bold">Opcje wyboru</label>
                            <input asp-for="Options" class="form-control" placeholder="np. Benzyna;Diesel;LPG" />
                            <div class="form-text">Wypełnij TYLKO jeśli wybrałeś typ <strong>Select</strong>. Rozdzielaj średnikiem (;).</div>
                        </div>

                        <div class="mb-3 bg-light p-3 rounded border">
                            <label class="form-label fw-bold small text-muted text-uppercase">Opcje zaawansowane</label>

                            <div class="mb-3">
                                <label class="form-label">Słownik zewnętrzny</label>
                                <select asp-for="DictionaryId" class="form-select" asp-items="ViewBag.Dictionaries">
                                    <option value="">— brak (użyj pola Opcje lub pola tekstowego) —</option>
                                </select>
                                <div class="form-text">Wybierz, jeśli typ to <strong>Dictionary</strong>.</div>
                            </div>

                            <div class="form-check form-switch">
                                <input asp-for="AllowMultiple" class="form-check-input" type="checkbox" />
                                <label asp-for="AllowMultiple" class="form-check-label">Pozwól na wybór wielu wartości</label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-light border px-4">Anuluj</a>
                            <button type="submit" class="btn btn-success px-4 fw-bold">Zapisz atrybut</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>