@model UncAds.Models.ForbiddenWord
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["CreateWordTitle"];
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="m-0 text-danger"><i class="bi bi-shield-plus"></i> @Localizer["CreateWordHeader"]</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Word" class="form-label fw-bold">@Localizer["WordLabel"]</label>
                            <input asp-for="Word" class="form-control" placeholder="@Localizer["WordPlaceholder"]" autofocus />
                            <span asp-validation-for="Word" class="text-danger small"></span>
                            <div class="form-text">@Localizer["WordHelpText"]</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success fw-bold">@Localizer["SaveButton"]</button>
                            <a asp-action="Index" class="btn btn-light border">@Localizer["CancelButton"]</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>