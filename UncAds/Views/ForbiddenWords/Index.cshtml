@model IEnumerable<UncAds.Models.ForbiddenWord>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["IndexTitle"];
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="m-0"><i class="bi bi-shield-x"></i> @Localizer["IndexHeader"]</h2>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg"></i> @Localizer["AddWordButton"]
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-check-circle fs-1 d-block mb-2"></i>
                    <span>@Localizer["NoWordsMessage"]</span>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">@Localizer["Table_WordHeader"]</th>
                                <th class="text-end pe-4">@Localizer["Table_ActionsHeader"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-danger">
                                        @w.Word
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-action="Delete" asp-route-id="@w.Id" class="btn btn-outline-danger btn-sm" title="@Localizer["Action_DeleteTitle"]">
                                            <i class="bi bi-trash"></i> @Localizer["Action_Delete"]
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>