@model UncAds.Models.AdReport
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["ResolveReportTitle"];
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 text-primary"><i class="bi bi-hammer"></i> @Localizer["ModeratorPanelHeader"]</h5>
                    <span class="badge bg-secondary">@Localizer["ReportIdLabel"] #@Model.Id</span>
                </div>
                <div class="card-body p-4">

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="small text-muted text-uppercase fw-bold">@Localizer["AdLabel"]</label>
                            <div class="fs-5 fw-bold">
                                @if (Model.Ad != null)
                                {
                                    <a asp-controller="Ads" asp-action="Details" asp-route-id="@Model.AdId" target="_blank">
                                        @Model.Ad.Title <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-danger">@Localizer["AdDeletedMessage"]</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="small text-muted text-uppercase fw-bold">@Localizer["ReportDateLabel"]</label>
                            <div>@Model.ReportDate</div>
                        </div>
                        <div class="col-12 bg-light p-3 rounded border">
                            <label class="small text-muted text-uppercase fw-bold mb-1">@Localizer["ReportReasonLabel"]</label>
                            <p class="m-0 fst-italic">"@Model.Reason"</p>
                        </div>
                    </div>

                    <hr />

                    @if (Model.Resolved)
                    {
                        <div class="alert alert-success border-success">
                            <h5 class="alert-heading"><i class="bi bi-check-circle-fill"></i> @Localizer["ReportClosedHeader"]</h5>
                            <p class="mb-0"><strong>@Localizer["ModeratorNoteLabel"]:</strong> @(Model.ResolutionNote ?? Localizer["NoNoteMessage"].ToString())</p>
                        </div>
                        <div class="d-grid">
                            <a asp-action="Reports" class="btn btn-secondary">@Localizer["BackToListButton"]</a>
                        </div>
                    }
                    else
                    {
                        <h5 class="mb-3"><i class="bi bi-pencil-square"></i> @Localizer["DecisionHeader"]</h5>
                        <form method="post" asp-action="ResolveReport" asp-route-id="@Model.Id">
                            @Html.AntiForgeryToken()

                            <div class="form-check form-switch mb-3 p-3 bg-danger bg-opacity-10 border border-danger rounded">
                                <input type="checkbox" class="form-check-input" id="deleteAd" name="deleteAd" value="true" style="cursor: pointer;">
                                @* Hidden input ensures a "false" value is sent if the checkbox is unchecked (standard ASP.NET Core MVC pattern) *@
                                <input type="hidden" name="deleteAd" value="false" /> 
                                <label for="deleteAd" class="form-check-label fw-bold text-danger" style="cursor: pointer;">
                                    @Localizer["DeleteAdOption"]
                                </label>
                                <div class="form-text text-danger">@Localizer["DeleteAdHelp"]</div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">@Localizer["ResolutionNoteLabel"]</label>
                                <textarea name="resolutionNote" class="form-control" rows="3" placeholder="@Localizer["ResolutionNotePlaceholder"]"></textarea>
                            </div>

                            <div class="d-flex justify-content-between">
                                <a asp-action="Reports" class="btn btn-light border px-4">@Localizer["CancelButton"]</a>
                                <button type="submit" class="btn btn-success px-4 fw-bold">@Localizer["ConfirmDecisionButton"]</button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>