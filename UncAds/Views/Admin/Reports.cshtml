@model List<UncAds.Models.AdReport>

@{
    ViewData["Title"] = "Zgłoszenia";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="m-0"><i class="bi bi-exclamation-octagon-fill text-danger"></i> Zgłoszenia nadużyć</h2>
        <a asp-action="Users" class="btn btn-outline-secondary btn-sm">Wróć do użytkowników</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Dotyczy ogłoszenia</th>
                            <th>Zgłaszający</th>
                            <th>Powód</th>
                            <th>Data</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Akcja</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-check2-all fs-1 d-block mb-2"></i>
                                    Brak nowych zgłoszeń.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var r in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">
                                        @if (r.Ad != null)
                                        {
                                            <a asp-controller="Ads" asp-action="Details" asp-route-id="@r.Ad.Id" target="_blank" class="text-decoration-none">
                                                @r.Ad.Title <i class="bi bi-box-arrow-up-right small"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-decoration-line-through text-muted">Ogłoszenie usunięte</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="small">@r.Reporter?.Email</div>
                                    </td>
                                    <td><span class="text-truncate d-inline-block" style="max-width: 200px;" title="@r.Reason">@r.Reason</span></td>
                                    <td class="small text-muted">@r.ReportDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (r.Resolved)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check"></i> Rozwiązane</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Oczekuje</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-action="ResolveReport" asp-route-id="@r.Id" class="btn btn-primary btn-sm rounded-pill px-3">
                                            Obsłuż
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>