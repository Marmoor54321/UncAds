@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["NewsletterTitle"];
}

<h2>@Localizer["NewsletterTitle"]</h2>

@if (ViewBag.Message != null)
{
    <div class="alert alert-success">@ViewBag.Message</div>
}

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Localizer["ManualSendHeader"]</h5>
        <p class="card-text">
            @Localizer["OperationDescription"]
        </p>
        <form asp-action="SendNewsletterConfirmed" method="post">
            <button type="submit" class="btn btn-primary">@Localizer["SendButton"]</button>
            <a asp-action="Users" class="btn btn-secondary">@Localizer["BackButton"]</a>
        </form>
    </div>
</div>