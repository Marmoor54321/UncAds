@model UncAds.Models.AdminSettings
@{
    ViewBag.Title = "Ustawienia administracyjne";
}

<h2>Ustawienia administracyjne</h2>

@if (ViewBag.Message != null)
{
    <div class="alert alert-success">@ViewBag.Message</div>
}

<form asp-action="Settings" method="post">
    <div class="form-group">
        <label asp-for="MaxAttachments"></label>
        <input asp-for="MaxAttachments" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="MaxFileSizeMB"></label>
        <input asp-for="MaxFileSizeMB" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="MaxMediaFiles"></label>
        <input asp-for="MaxMediaFiles" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="HomePageMessage"></label>
        <textarea asp-for="HomePageMessage" class="form-control" rows="3"></textarea>
    </div>

    <button type="submit" class="btn btn-primary mt-2">Zapisz</button>
</form>
