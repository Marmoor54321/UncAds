@model UncAds.Models.ApplicationUser

@{
    ViewData["Title"] = "Zarządzanie rolami";
    var allRoles = ViewBag.AllRoles as List<string>;
    var userRoles = ViewBag.UserRoles as IList<string>;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="m-0 text-primary"><i class="bi bi-shield-check"></i> Zarządzanie uprawnieniami</h5>
                </div>
                <div class="card-body p-4">

                    <div class="mb-4 text-center">
                        <span class="text-muted small text-uppercase">Użytkownik</span>
                        <h4 class="fw-bold text-dark">@Model.Email</h4>
                    </div>

                    <form asp-action="EditRole" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="list-group mb-4">
                            @foreach (var role in allRoles)
                            {
                                <label class="list-group-item d-flex gap-3 align-items-center cursor-pointer">
                                    <input class="form-check-input flex-shrink-0" type="checkbox" name="selectedRoles" value="@role"
                                           @(userRoles.Contains(role) ? "checked" : "") style="font-size: 1.3em;">
                                    <span class="pt-1 form-checked-content">
                                        <strong>@role</strong>
                                        <small class="d-block text-muted">Przyznaje uprawnienia grupy @role.</small>
                                    </span>
                                </label>
                            }
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary fw-bold">Zapisz uprawnienia</button>
                            <a asp-action="Users" class="btn btn-light border">Powrót</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>