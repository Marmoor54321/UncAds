@model IEnumerable<UncAds.Models.ApplicationUser>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["ManageUsersTitle"];
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <h2 class="m-0"><i class="bi bi-people-fill"></i> @Localizer["UsersHeader"]</h2>

        <div class="btn-group">
            <a asp-action="Reports" class="btn btn-warning shadow-sm">
                <i class="bi bi-flag-fill"></i> @Localizer["ReportsButton"]
            </a>
            <a asp-action="SendNewsletter" class="btn btn-info shadow-sm text-white">
                <i class="bi bi-envelope-paper-fill"></i> @Localizer["NewsletterButton"]
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">@Localizer["Table_UserEmail"]</th>
                            <th>@Localizer["Table_Id"]</th>
                            <th class="text-end pe-4">@Localizer["Table_Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">
                                    <i class="bi bi-person-circle text-secondary me-2"></i> @user.Email
                                </td>
                                <td><small class="text-muted font-monospace">@user.Id</small></td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditRole" asp-route-id="@user.Id" class="btn btn-outline-primary" title="@Localizer["ManageRolesTitle"]">
                                            <i class="bi bi-shield-lock"></i> @Localizer["RolesButton"]
                                        </a>
                                        <a asp-action="DeleteUser" asp-route-id="@user.Id" class="btn btn-outline-danger" title="@Localizer["DeleteUserTitle"]">
                                            <i class="bi bi-trash"></i> @Localizer["DeleteButton"]
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>