@model IEnumerable<UncAds.Models.ApplicationUser>

@{
    ViewData["Title"] = "Zarządzanie użytkownikami";
}

<h2 class="d-flex justify-content-between align-items-center">
    Zarządzanie użytkownikami

    <a asp-action="Reports" class="btn btn-warning">
        Zgłoszenia do moderacji
    </a>
</h2>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Email</th>
            <th>ID</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.Id</td>
                <td>
                    <a asp-action="EditRole" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Role</a>
                    <a asp-action="DeleteUser" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Usuń</a>
                </td>
            </tr>
        }
    </tbody>
</table>
